---
layout: page.njk
title: Projects
navItem: projects
breadcrumb: projects
subtitle: personal software, experiments & physical builds
pageCSS: /css/projects.css
---

<div class="page-content">

    <!-- Software -->
    <section class="site-section">
        <div class="site-section-header"><h2>Software</h2></div>
        <div class="project-grid">
            {% for item in personal_projects %}
            {% if item.type == 'software' %}
            <a href="{{ item.url }}" class="project-card" {% if item.url != '#' %}target="_blank" rel="noopener"{% endif %}>
                <div class="pc-head">
                    <span class="pc-name">{{ item.name }}</span>
                    <span class="pc-status pc-status--{{ item.status | replace(' ', '') }}">{{ item.status }}</span>
                </div>
                <p class="pc-desc">{{ item.description }}</p>
                <div class="pc-foot">
                    {% if item.stack %}<span class="pc-stack">{{ item.stack }}</span>{% endif %}
                    <span class="pc-year">{{ item.year }}</span>
                </div>
            </a>
            {% endif %}
            {% endfor %}
        </div>
    </section>

    <!-- Builds -->
    <section class="site-section">
        <div class="site-section-header"><h2>Builds</h2></div>
        <div class="project-grid">
            {% for item in personal_projects %}
            {% if item.type == 'physical' %}
            <div class="project-card">
                <div class="pc-head">
                    <span class="pc-name">{{ item.name }}</span>
                    <span class="pc-status pc-status--{{ item.status | replace(' ', '') }}">{{ item.status }}</span>
                </div>
                <p class="pc-desc">{{ item.description }}</p>
                <div class="pc-foot">
                    <span class="pc-year">{{ item.year }}</span>
                </div>
            </div>
            {% endif %}
            {% endfor %}
        </div>
    </section>

</div>
