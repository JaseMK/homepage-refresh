<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ pageTitle if pageTitle else site.title }}{% endif %}</title>
    <meta name="description" content="{{ pageDescription if pageDescription else site.description }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;1,6..72,400;1,6..72,600&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/css/tokens.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/base.css' | url }}">
    {% if pageCSS %}<link rel="stylesheet" href="{{ pageCSS | url }}">{% endif %}
</head>
<body>

<nav id="nav">
    <a href="{{ '/' | url }}" class="nav-logo">Jason Carvalho</a>
    <ul class="nav-tabs" id="navTabs">
        <li><a href="{{ '/' | url }}#work">Work</a></li>
        <li><a href="{{ '/' | url }}#projects">Projects</a></li>
        <li><a href="{{ '/' | url }}#photos">Photos</a></li>
        <li><a href="{{ '/sim-racing/' | url }}" {% if navItem == 'sim-racing' %}class="active"{% endif %}>Sim Racing ↗</a></li>
    </ul>
    <div class="nav-toggle" id="navToggle" role="button" tabindex="0" aria-label="Toggle menu">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6"  x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </div>
</nav>

{{ content | safe }}

<footer>
    <span class="footer-name">Jason Carvalho</span>
    <div class="footer-socials">
        <a href="https://instagram.com/jase_mk/" target="_blank" rel="noopener">instagram</a>
        <a href="https://flickr.com/photos/jase_mk/" target="_blank" rel="noopener">flickr</a>
        <a href="https://youtube.com/@JaseMK2001" target="_blank" rel="noopener">youtube</a>
        <a href="https://facebook.com/jason.carvalho" target="_blank" rel="noopener">facebook</a>
    </div>
    <span class="footer-copy">© {{ site.currentYear }}</span>
</footer>

<script src="{{ '/js/nav.js' | url }}"></script>
{% if pageJS %}<script src="{{ pageJS | url }}"></script>{% endif %}

</body>
</html>
