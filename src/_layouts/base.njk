<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ pageTitle if pageTitle else site.title }}{% endif %}</title>
    <meta name="description" content="{{ pageDescription if pageDescription else site.description }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/css/tokens.css' | url }}">
    <link rel="stylesheet" href="{{ '/css/base.css' | url }}">
    {% if pageCSS %}<link rel="stylesheet" href="{{ pageCSS | url }}">{% endif %}
</head>
<body>

<nav id="nav">
    <a href="{{ '/' | url }}" class="nav-logo">jc</a>
    <ul class="nav-tabs" id="navTabs">
        <li><a href="{{ '/' | url }}"              {% if navItem == 'home'       %}class="active"{% endif %}>home</a></li>
        <li><a href="{{ '/work/' | url }}"         {% if navItem == 'work'       %}class="active"{% endif %}>work</a></li>
        <li><a href="{{ '/projects/' | url }}"     {% if navItem == 'projects'   %}class="active"{% endif %}>projects</a></li>
        <li><a href="{{ '/photos/' | url }}"       {% if navItem == 'photos'     %}class="active"{% endif %}>photos</a></li>
        <li><a href="{{ '/sim-racing/' | url }}"   {% if navItem == 'sim-racing' %}class="active"{% endif %}>sim racing</a></li>
    </ul>
    <div class="nav-toggle" id="navToggle" role="button" tabindex="0" aria-label="Toggle menu">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6"  x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </div>
</nav>

{{ content | safe }}

<footer>
    <span>{{ site.domain }}</span>
    <span>© {{ site.currentYear }} {{ site.author }}</span>
</footer>

<script src="{{ '/js/nav.js' | url }}"></script>
{% if pageJS %}<script src="{{ pageJS | url }}"></script>{% endif %}

</body>
</html>
