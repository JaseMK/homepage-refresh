---
layout: page.njk
title: Work
navItem: work
breadcrumb: work
subtitle: research, publications & tools built at work
pageCSS: /css/work.css
---

<div class="page-content">

    <!-- Research -->
    <section class="site-section">
        <div class="site-section-header"><h2>Research</h2></div>
        {% for item in research %}
        <div class="research-row">
            <span class="rr-year">{{ item.year }}</span>
            <div class="rr-body">
                <div class="rr-title">{{ item.title }}</div>
                <div class="rr-tags">
                    {% for tag in item.tags %}
                    <span class="tag">{{ tag }}</span>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endfor %}
    </section>

    <!-- Publications -->
    <section class="site-section">
        <div class="site-section-header"><h2>Publications</h2></div>
        {% for item in publications %}
        <div class="pub-row">
            <span class="pub-num">[{{ loop.index | zeroPad(2) }}]</span>
            <div class="pub-body">
                <div class="pub-authors">{{ item.authors }}</div>
                <div class="pub-title">{{ item.title }}</div>
                <div class="pub-venue">{{ item.venue }}</div>
            </div>
            <span class="pub-year">{{ item.year }}</span>
        </div>
        {% endfor %}
    </section>

    <!-- Tools & Applications -->
    <section class="site-section">
        <div class="site-section-header"><h2>Tools &amp; Applications</h2></div>
        <div class="tool-grid">
            {% for item in work_tools %}
            <a href="{{ item.url }}" class="tool-card" {% if item.url != '#' %}target="_blank" rel="noopener"{% endif %}>
                <div class="tc-head">
                    <span class="tc-name">{{ item.name }}</span>
                    <span class="tc-status">{{ item.status }}</span>
                </div>
                <p class="tc-desc">{{ item.description }}</p>
                <span class="tc-stack">{{ item.stack }}</span>
            </a>
            {% endfor %}
        </div>
    </section>

    <!-- External Project Websites -->
    <section class="site-section">
        <div class="site-section-header"><h2>Project Websites</h2></div>
        {% for item in work_external %}
        <a href="{{ item.url }}" class="ext-row" {% if item.url != '#' %}target="_blank" rel="noopener"{% endif %}>
            <span class="ext-name">{{ item.name }}</span>
            <span class="ext-url">{{ item.url_label }} ↗</span>
        </a>
        {% endfor %}
    </section>

</div>
