---
layout: page.njk
title: Work
navItem: work
breadcrumb: work
subtitle: publications, research & tools built for work
pageCSS: /css/work.css
---

{% set dotColors = ['blue', 'purple', 'green'] %}

<!-- ============================================================
     RESEARCH PROJECTS
     ============================================================ -->
<section id="research">
    <div class="section-inner">
        <div class="section-header">
            <span class="sh-path">work/</span><span class="sh-name">research</span>
        </div>
        <div class="section-title">
            <span class="kw-prefix">// projects</span>
            Research
        </div>

        <div class="subsection">
            <div class="subsection-header">
                <span class="ss-dot" style="background:var(--green)"></span>
                <span class="ss-fname">research projects</span>
                <span class="ss-badge">research</span>
            </div>
            <div class="research-grid">
                {% for item in research %}
                <div class="rc">
                    <div class="rc-fileheader">
                        <div class="rc-lang-dot" style="background:var(--{{ dotColors[loop.index0 % 3] }})"></div>
                        <span>{{ item.id }}</span>
                    </div>
                    <div class="rc-body">
                        <div class="rc-year">{{ item.year }}</div>
                        <h3 class="rc-title">{{ item.title }}</h3>
                        <p class="rc-desc">{{ item.description }}</p>
                        <div class="rc-tags">
                            {% for tag in item.tags %}
                            <span class="tag">{{ tag }}</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     TOOLS & APPLICATIONS
     ============================================================ -->
<section id="tools" style="background:var(--bg-2)">
    <div class="section-inner">
        <div class="section-header">
            <span class="sh-path">work/</span><span class="sh-name">tools</span>
        </div>
        <div class="section-title">
            <span class="kw-prefix">// built for work</span>
            Tools & Applications
        </div>

        <div class="subsection">
            <div class="subsection-header">
                <span class="ss-dot" style="background:var(--blue)"></span>
                <span class="ss-fname">apps &amp; tools</span>
                <span class="ss-badge">built</span>
            </div>
            <div class="tools-grid">
                {% for item in work_tools %}
                <a href="{{ item.url }}" class="tool-card" {% if item.url != '#' %}target="_blank" rel="noopener"{% endif %}>
                    <div class="tool-card-header">
                        <span>{{ item.id }}/</span>
                        <span class="tool-badge">{{ item.status }}</span>
                    </div>
                    <div class="tool-body">
                        <div class="tool-name">{{ item.name }}</div>
                        <p class="tool-desc">{{ item.description }}</p>
                    </div>
                    <div class="tool-footer">
                        <span class="cm">// {{ item.stack }}</span>
                        <span class="tool-link-label">visit <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
                    </div>
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     PUBLICATIONS
     ============================================================ -->
<section id="publications">
    <div class="section-inner">
        <div class="section-header">
            <span class="sh-path">work/</span><span class="sh-name">publications</span>
        </div>
        <div class="section-title">
            <span class="kw-prefix">// peer-reviewed</span>
            Publications
        </div>

        <div class="subsection">
            <div class="subsection-header">
                <span class="ss-dot" style="background:var(--orange)"></span>
                <span class="ss-fname">publications</span>
                <span class="ss-badge">papers</span>
            </div>
            <div class="pub-list">
                {% for item in publications %}
                <div class="pub-item">
                    <span class="pub-ref">[{{ loop.index | zeroPad(2) }}]</span>
                    <div>
                        <div class="pub-authors">{{ item.authors }}</div>
                        <div class="pub-title">{{ item.title }}</div>
                        <div class="pub-venue">{{ item.venue }}</div>
                    </div>
                    <span class="pub-year">{{ item.year }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
